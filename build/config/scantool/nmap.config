# Script Enablers -->

scantool_nmap_enable="1"
scantool_nmap_updatedb="1"
## Enable/disables pre-scan NSE Script Database updates

scantool_nmap_fastscan_enable="1"
## Enables/disables the FastScan Script

scantool_nmap_traceroute_enable="1"
## Enables/disables the Traceroute Script
## This function sometimes takes a long to finish

scantool_nmap_fullscan_enable="1"
## Enables/disables the FullScan Script
## This is a basic service discovery, and
## host identification script. Enabled
## by default.

scantool_nmap_nsescriptscan_enable="1"
## Enables/disables the Prototype NMap NSE Script Scan
## Allows custom target scans using nse scripts.

scantool_nmap_nsescripttrace="0"
## Enables/disables NSE Script Trace (Verbose Output)
## This WILL fill up your screen with multiple lines of info.
## Used for debug purposes only.

# <-- Script Enablers

# Script Variables -->

scantool_nmap_fastscan_output="nmap-fastscan.txt"
## Output Filename for FastScan Function of the NMap Tool
## NOT A LOCATION HANDLER!

scantool_nmap_traceroute_output="nmap-traceroute.txt"
## Output Filename for TraceRoute Function of the NMap Tool
## NOT A LOCATION HANDLER!

scantool_nmap_fullscan_output="nmap-fullscan.txt"
## Output Filename for FullScan Function of the NMap Tool
## NOT A LOCATION HANDLER!

scantool_nmap_nsescriptscan_output="nmap-scriptnse.txt"
## Output Filename for NSE Script Scan Function of the NMap Tool
## NOT A LOCATION HANDLER!

# <-- Script Variables