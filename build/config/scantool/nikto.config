# Script Enablers -->

scantool_nikto_enable="1"

scantool_nikto_forcessl_enable="0"
## Enables/disables ForceSSL Mode.
## Disable the http/https scan functions
## to use this option standalone.
## ForceSSL also Forces Port 443 Use!

scantool_nikto_http_enable="1"
## Enables/disables the HTTP scan

scantool_nikto_https_enable="1"
## Enables/disables the HTTPS scan

# <-- Script Enablers

# Script Variables -->

scantool_nikto_http_output="nikto-http.txt"
## Output Filename for the HTTP-log of the Nikto Tool
## NOT A LOCATION HANDLER!

scantool_nikto_https_output="nikto-https.txt"
## Output Filename for the HTTPS-log of the Nikto Tool
## NOT A LOCATION HANDLER!

scantool_nikto_forcessl_output="nikto-forcessl.txt"
## Output Filename for the ForceSSL-log of the Nikto Tool
## NOT A LOCATION HANDLER!

# <-- Script Variables